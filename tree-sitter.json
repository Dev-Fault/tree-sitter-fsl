{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "fsl",
      "camelcase": "Fsl",
      "title": "FSL",
      "scope": "source.fsl",
      "file-types": [
        "fsl"
      ],
      "injection-regex": "^fsl$",
      "class-name": "TreeSitterFsl"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "fsl parser",
    "authors": [
      {
        "name": "devfault",
        "email": "devfaultapps@gmail.com",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-fsl",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}